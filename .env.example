# Get a token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Public site URL for link previews (Open Graph), e.g. https://your-app.vercel.app
# NEXT_PUBLIC_APP_URL=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# Resend Segment ID — Dashboard → Segments → your audience → ID
RESEND_SEGMENT_ID=

# Legacy alias if your dashboard still shows "Audience ID"
# RESEND_AUDIENCE_ID=

# Optional override for admin page password (default: northlondonforever)
# ADMIN_PASSWORD=
